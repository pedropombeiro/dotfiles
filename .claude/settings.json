{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "[ -n \"$(yadm ls-files $CLAUDE_FILE_PATHS 2>/dev/null)\" ] && mise run dotfiles:fix -- $CLAUDE_FILE_PATHS || true",
            "type": "command"
          }
        ],
        "matcher": "Edit"
      },
      {
        "hooks": [
          {
            "command": "[ -n \"$(yadm ls-files $CLAUDE_FILE_PATHS 2>/dev/null)\" ] && mise run dotfiles:fix -- $CLAUDE_FILE_PATHS || true",
            "type": "command"
          }
        ],
        "matcher": "Write"
      }
    ]
  },
  "model": "opus[1m]",
  "permissions": {
    "allow": ["mcp__incident_io__*", "Skill(incident)"]
  },
  "statusLine": {
    "command": "npx -y ccstatusline@latest",
    "padding": 0,
    "type": "command"
  }
}
