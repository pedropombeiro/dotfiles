redactions = ["*_API_KEY", "*_TOKEN"]

[env]
_.source = { path = ".config/mise/.github_token.sh", redact = true }

[settings]
jobs = 1
idiomatic_version_file_enable_tools = []

[settings.pipx]
uvx = true

[tools]
# ── Runtimes & infra ──────────────────────────────────────────────────
# JavaScript runtime
node = "latest"
# Ruby runtime
ruby = "4.0.5"
# Rust toolchain
rust = "stable"
# cURL-like tool for gRPC servers
grpcurl = "latest"
# YAML linter
yamllint = "latest"

# ── AI tooling ────────────────────────────────────────────────────

# AI coding assistant CLI
"opencode" = { version = "latest", no_app = true }
# A CLI tool for tracking token usage
"npm:tokscale" = "latest"

# ── GitHub releases ───────────────────────────────────────────────────
# Terminal file manager
"github:sxyazi/yazi" = "26.5.6"

# ── Ruby gems ─────────────────────────────────────────────────────────
# Ruby provider for Neovim plugins
"gem:neovim" = "0.10.0"
# Ruby LSP language server
"gem:ruby-lsp" = "0.26.9"
# Ruby linter/formatter (StandardRB)
"gem:standard" = "latest"

# ── Neovim integration ────────────────────────────────────────────────
# Open files in an existing Neovim instance
"pipx:neovim-remote" = "2.5.1"

# ── Video editing tools ────────────────────────────────────────────────
# Programs to process GoPro MP4 & Generic GPX/FIT files and create video dashboards & maps
"pipx:gopro-overlay" = "0.134.0"

# ── Brew ──────────────────────────────────────────────────────────────

[tasks."brew:dump"]
description = "Dump current Homebrew packages to Brewfile"
run = "brew bundle dump --global --describe --force --formula --cask --tap"

[tasks."brew:cleanup"]
description = "Remove packages not in Brewfile"
run = "brew bundle cleanup --file ~/.Brewfile --force"

# ── Network ───────────────────────────────────────────────────────────

[tasks."network:wifi-traffic"]
description = "Sniff Wi-Fi traffic from the AP"
run = 'ssh ap-u6pro.infra.pombei.ro "tcpdump -np"'
