#!/bin/sh
set -eu

version="$ASDF_INSTALL_VERSION"
install_path="$ASDF_INSTALL_PATH"
download_path="$ASDF_DOWNLOAD_PATH"
archive_path="$download_path"

if [ -d "$download_path" ]; then
  archive_path=$(find "$download_path" -maxdepth 2 -type f -name 'node-v*-linux-x64-musl.tar.gz' | head -n 1)
fi

if [ -z "$archive_path" ] || [ ! -f "$archive_path" ]; then
  echo "node-musl archive not found in $download_path" >&2
  exit 1
fi

mkdir -p "$install_path"
tar -xzf "$archive_path" -C "$install_path" --strip-components=1

mv "$install_path/bin/node" "$install_path/bin/node-real"
mv "$install_path/bin/npm" "$install_path/bin/npm-real"
mv "$install_path/bin/npx" "$install_path/bin/npx-real"
for tool in corepack pnpm pnpx yarn yarnpkg; do
  if [ -e "$install_path/bin/$tool" ]; then
    mv "$install_path/bin/$tool" "$install_path/bin/${tool}-real"
  fi
done

cat >"$install_path/bin/node" <<'EOF'
#!/bin/sh
script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
install_root=$(CDPATH= cd -- "$script_dir/.." && pwd)
runtime_root=${MISE_NODE_MUSL_RUNTIME:-$HOME/opt/musl-runtime}
export LD_LIBRARY_PATH="$runtime_root/usr/lib:$runtime_root/lib"
exec "$runtime_root/lib/ld-musl-x86_64.so.1" "$install_root/bin/node-real" "$@"
EOF

chmod +x "$install_path/bin/node"

cat >"$install_path/bin/npm" <<'EOF'
#!/bin/sh
script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
exec "$script_dir/node" "$script_dir/npm-real" "$@"
EOF

chmod +x "$install_path/bin/npm"

cat >"$install_path/bin/npx" <<'EOF'
#!/bin/sh
script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
exec "$script_dir/node" "$script_dir/npx-real" "$@"
EOF

chmod +x "$install_path/bin/npx"

for tool in corepack pnpm pnpx yarn yarnpkg; do
  [ -e "$install_path/bin/${tool}-real" ] || continue
  cat >"$install_path/bin/$tool" <<EOF
#!/bin/sh
script_dir=\$(CDPATH= cd -- "\$(dirname "\$0")" && pwd)
exec "\$script_dir/node" "\$script_dir/${tool}-real" "\$@"
EOF
  chmod +x "$install_path/bin/$tool"
done
