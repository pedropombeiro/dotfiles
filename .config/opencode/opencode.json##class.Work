{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "plugin": [
    "@gitlab/opencode-gitlab-plugin",
    "@mohak34/opencode-notifier@latest",
    "opencode-atuin-history@latest",
    "opencode-forge-session-title@latest",
    "opencode-homeassistant@latest",
    "opencode-terminal-progress@latest",
    "opencode-tmux-indicator@latest",
    "opencode-wakatime@latest"
  ],
  "mcp": {
    "lazy-mcp": {
      "type": "local",
      "command": [
        "mise",
        "x",
        "npm:lazy-mcp",
        "--",
        "lazy-mcp",
        "--config",
        "~/.config/lazy-mcp/servers.json"
      ],
      "enabled": true
    }
  },
  "enabled_providers": ["gitlab"],
  "small_model": "gitlab/duo-chat-haiku-4-5",
  "provider": {
    "gitlab": {
      "models": {
        "duo-chat-opus-4-6": {
          "cost": {
            "input": 5, "output": 25, "cache_read": 0.50, "cache_write": 6.25,
            "context_over_200k": { "input": 10, "output": 37.50, "cache_read": 1.00, "cache_write": 12.50 }
          }
        },
        "duo-chat-opus-4-5": {
          "cost": {
            "input": 5, "output": 25, "cache_read": 0.50, "cache_write": 6.25,
            "context_over_200k": { "input": 10, "output": 37.50, "cache_read": 1.00, "cache_write": 12.50 }
          }
        },
        "duo-chat-sonnet-4-6": {
          "cost": {
            "input": 3, "output": 15, "cache_read": 0.30, "cache_write": 3.75,
            "context_over_200k": { "input": 6, "output": 22.50, "cache_read": 0.60, "cache_write": 7.50 }
          }
        },
        "duo-chat-sonnet-4-5": {
          "cost": {
            "input": 3, "output": 15, "cache_read": 0.30, "cache_write": 3.75,
            "context_over_200k": { "input": 6, "output": 22.50, "cache_read": 0.60, "cache_write": 7.50 }
          }
        },
        "duo-chat-sonnet-4": {
          "cost": {
            "input": 3, "output": 15, "cache_read": 0.30, "cache_write": 3.75,
            "context_over_200k": { "input": 6, "output": 22.50, "cache_read": 0.60, "cache_write": 7.50 }
          }
        },
        "duo-chat-opus-4": {
          "cost": {
            "input": 15, "output": 75, "cache_read": 1.50, "cache_write": 18.75,
            "context_over_200k": { "input": 30, "output": 112.50, "cache_read": 3.00, "cache_write": 37.50 }
          }
        },
        "duo-chat-haiku-4-5": {
          "cost": { "input": 1, "output": 5, "cache_read": 0.10, "cache_write": 1.25 }
        }
      }
    }
  },
  "share": "disabled",
  "snapshot": false,
  "permission": {
    "*": "ask",
    "bash": {
      "*": "ask",
      "bundle exec rspec*": "allow",
      "bundle exec rubocop*": "allow",
      "cat *": "allow",
      "diff *": "allow",
      "docker container ls*": "allow",
      "docker image ls*": "allow",
      "docker images*": "allow",
      "docker info*": "allow",
      "docker inspect *": "allow",
      "docker network inspect *": "allow",
      "docker network ls *": "allow",
      "docker ps*": "allow",
      "docker stats*": "allow",
      "docker version*": "allow",
      "docker volume ls *": "allow",
      "echo *": "allow",
      "env *": "allow",
      "file *": "allow",
      "find *": "allow",
      "date *": "allow",
      "git add *": "allow",
      "git blame *": "allow",
      "git branch *": "allow",
      "git check-ignore *": "allow",
      "git diff*": "allow",
      "git fetch *": "allow",
      "git grep*": "allow",
      "git log*": "allow",
      "git ls-files*": "allow",
      "git ls-remote *": "allow",
      "git merge-base *": "allow",
      "git reflog *": "allow",
      "git remote -v": "allow",
      "git rev-parse*": "allow",
      "git show*": "allow",
      "git status*": "allow",
      "glab issue list *": "allow",
      "glab issue view *": "allow",
      "glab mr create *": "allow",
      "glab mr diff *": "allow",
      "glab mr list *": "allow",
      "glab mr view *": "allow",
      "go build*": "allow",
      "go test*": "allow",
      "go vet*": "allow",
      "golangci-lint run*": "allow",
      "grep *": "allow",
      "head *": "allow",
      "ls *": "allow",
      "markdownlint *": "allow",
      "md5 *": "allow",
      "mise ls *": "allow",
      "mise ls-remote *": "allow",
      "mise tasks": "allow",
      "mise tasks --list": "allow",
      "mise tasks --silent": "allow",
      "mise tasks info *": "allow",
      "mise tasks ls *": "allow",
      "npx markdownlint-cli2 *": "allow",
      "pre-commit *": "allow",
      "printenv *": "allow",
      "printf *": "allow",
      "RAILS_ENV=test bundle exec rspec*": "allow",
      "RAILS_ENV=test bundle exec rubocop*": "allow",
      "readlink *": "allow",
      "rg *": "allow",
      "sed *": "allow",
      "shellcheck *": "allow",
      "sleep *": "allow",
      "stat *": "allow",
      "strings *": "allow",
      "tail *": "allow",
      "vale *": "allow",
      "wc *": "allow",
      "which *": "allow",
      "xxd *": "allow",
      "yamllint *": "allow"
    },
    "external_directory": {
      "~/.agents/docs/*": "allow",
      "/tmp": "allow",
      "/tmp/*": "allow",
      "/private/tmp/**/*": "allow",
      "/private/tmp/*": "allow",
      "/private/tmp": "allow"
    },
    "glob": "allow",
    "grep": "allow",
    "knowledge-graph_get_references": "allow",
    "knowledge-graph_list_projects": "allow",
    "knowledge-graph_read_definitions": "allow",
    "knowledge-graph_repo_map": "allow",
    "knowledge-graph_search_codebase_definitions": "allow",
    "lazy-mcp_describe_commands": "allow",
    "lazy-mcp_invoke_command": "allow",
    "lazy-mcp_list_commands": "allow",
    "lazy-mcp_list_servers": "allow",
    "read": "allow",
    "skill": { "clickhouse": "allow", "glab": "allow", "mr-workflow": "allow", "psql": "allow" },
    "task": {
      "general": "allow",
      "explore": "allow",
      "review-security": "allow",
      "review-database": "allow",
      "review-clickhouse": "allow",
      "review-performance": "allow",
      "review-qa": "allow",
      "review-frontend": "allow",
      "review-backend": "allow",
      "review-docs": "allow",
      "review-analytics": "allow",
      "review-graphql": "allow"
    },
    "todowrite": "allow"
  }
}
