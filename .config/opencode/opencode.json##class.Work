{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "plan": {
      "model": "gitlab/duo-chat-opus-4-6"
    },
    "build": {
      "model": "gitlab/duo-chat-sonnet-4-6"
    }
  },
  "default_agent": "plan",
  "plugin": [
    "opencode-gitlab-plugin@latest",
    "@mohak34/opencode-notifier@latest",
    "opencode-atuin-history@latest",
    "opencode-claude-prefill-fix@latest",
    "opencode-forge-session-title@latest",
    "opencode-homeassistant@latest",
    "opencode-terminal-progress@latest",
    "opencode-tmux-indicator@latest",
    "opencode-wakatime@latest"
  ],
  "mcp": {
    "lazy-mcp": {
      "type": "local",
      "command": [
        "mise",
        "x",
        "npm:lazy-mcp",
        "--",
        "lazy-mcp",
        "--config",
        "~/.config/lazy-mcp/servers.json"
      ],
      "enabled": true
    }
  },
  "enabled_providers": ["ollama", "gitlab", "anthropic", "google"],
  "small_model": "gitlab/duo-chat-gpt-5-4-nano",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "gemma4": {
          "name": "Gemma 4"
        },
        "gemma4:26b": {
          "name": "Gemma 4 26B MoE"
        },
        "gemma4:e2b": {
          "name": "Gemma 4:e2b"
        }
      }
    },
    "gitlab": {
      "models": {
        "duo-workflow-opus-4-6": {
          "cost": {
            "input": 5, "output": 25, "cache_read": 0.50, "cache_write": 6.25
          }
        },
        "duo-chat-opus-4-6": {
          "cost": {
            "input": 5, "output": 25, "cache_read": 0.50, "cache_write": 6.25
          }
        },
        "duo-chat-opus-4-5": {
          "cost": {
            "input": 5, "output": 25, "cache_read": 0.50, "cache_write": 6.25
          }
        },
        "duo-chat-sonnet-4-6": {
          "cost": {
            "input": 3, "output": 15, "cache_read": 0.30, "cache_write": 3.75
          }
        },
        "duo-chat-sonnet-4-5": {
          "cost": {
            "input": 3, "output": 15, "cache_read": 0.30, "cache_write": 3.75
          }
        },
        "duo-chat-sonnet-4": {
          "cost": {
            "input": 3, "output": 15, "cache_read": 0.30, "cache_write": 3.75
          }
        },
        "duo-chat-opus-4": {
          "cost": {
            "input": 15, "output": 75, "cache_read": 1.50, "cache_write": 18.75
          }
        },
        "duo-workflow-haiku-4-5": {
          "cost": { "input": 1, "output": 5, "cache_read": 0.10, "cache_write": 1.25 }
        },
        "duo-chat-haiku-4-5": {
          "cost": { "input": 1, "output": 5, "cache_read": 0.10, "cache_write": 1.25 }
        },
        "duo-chat-gpt-5-3-codex": {
          "cost": { "input": 1.75, "output": 14, "cache_read": 0.175 }
        },
        "duo-chat-gpt-5-2-codex": {
          "cost": { "input": 1.50, "output": 12, "cache_read": 0.15 }
        },
        "duo-chat-gpt-5-mini": {
          "cost": { "input": 0.75, "output": 3, "cache_read": 0.075 }
        },
        "duo-chat-gpt-5-4": {
          "cost": { "input": 2.50, "output": 15, "cache_read": 0.25 }
        },
        "duo-chat-gpt-5-4-mini": {
          "cost": { "input": 1.10, "output": 4.40, "cache_read": 0.11 }
        },
        "duo-chat-gpt-5-4-nano": {
          "cost": { "input": 0.50, "output": 2.00, "cache_read": 0.05 }
        }
      },
      "options": {
        "instanceUrl": "https://gitlab.com",
        "featureFlags": {
          "duo_agent_platform_agentic_chat": true,
          "duo_agent_platform": true
        }
      }
    }
  },
  "share": "disabled",
  "autoupdate": false,
  "server": {
    "hostname": "127.0.0.1",
    "mdns": false
  },
  "snapshot": false,
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "bash": {
      "*": "ask",
      "bundle exec rspec*": "allow",
      "bundle exec rubocop*": "allow",
      "cat *": "allow",
      "diff *": "allow",
      "docker container ls*": "allow",
      "docker image ls*": "allow",
      "docker images*": "allow",
      "docker info*": "allow",
      "docker inspect *": "allow",
      "docker network inspect *": "allow",
      "docker network ls *": "allow",
      "docker ps*": "allow",
      "docker stats*": "allow",
      "docker version*": "allow",
      "docker volume ls *": "allow",
      "echo *": "allow",
      "env *": "allow",
      "file *": "allow",
      "find *": "allow",
      "date": "allow",
      "date *": "allow",
      "git add *": "allow",
      "git blame *": "allow",
      "git branch*": "allow",
      "git branch *": "allow",
      "git check-ignore *": "allow",
      "git commit*": "ask",
      "git commit *": "ask",
      "git diff*": "allow",
      "git fetch *": "allow",
      "git grep*": "allow",
      "git log*": "allow",
      "git ls-files*": "allow",
      "git ls-remote *": "allow",
      "git merge-base *": "allow",
      "git push*": "ask",
      "git push *": "ask",
      "git reflog *": "allow",
      "git remote -v": "allow",
      "git rev-parse*": "allow",
      "git show*": "allow",
      "git status*": "allow",
      "gdk psql*": "allow",
      ".opencode/skills/clickhouse/scripts/gdk-clickhouse *": "allow",
      "CLICKHOUSE_USER=* .opencode/skills/clickhouse/scripts/gdk-clickhouse *": "allow",
      "CLICKHOUSE_GDK_GITLAB_USER_PASSWORD=* .opencode/skills/clickhouse/scripts/gdk-clickhouse *": "allow",
      "CLICKHOUSE_USER=* CLICKHOUSE_GDK_GITLAB_USER_PASSWORD=* .opencode/skills/clickhouse/scripts/gdk-clickhouse *": "allow",
      "glab issue list *": "allow",
      "glab issue view *": "allow",
      "glab mr create *": "allow",
      "glab mr diff *": "allow",
      "glab mr list *": "allow",
      "glab mr view *": "allow",
      "go build*": "allow",
      "go test*": "allow",
      "go vet*": "allow",
      "golangci-lint run*": "allow",
      "grep *": "allow",
      "head *": "allow",
      "hostname": "allow",
      "ls *": "allow",
      "man *": "deny", // Context7 should be used instead
      "markdownlint *": "allow",
      "md5 *": "allow",
      "mise ls *": "allow",
      "mise x clickhouse *": "allow",
      "mise ls-remote *": "allow",
      "mise tasks": "allow",
      "mise tasks --list": "allow",
      "mise tasks --silent": "allow",
      "mise tasks info *": "allow",
      "mise tasks ls *": "allow",
      "npx markdownlint-cli2 *": "allow",
      "pre-commit *": "allow",
      "printenv *": "allow",
      "printf *": "allow",
      "ps *": "allow",
      "pwd": "allow",
      "RAILS_ENV=test bundle exec rspec*": "allow",
      "RAILS_ENV=test bundle exec rubocop*": "allow",
      "readlink *": "allow",
      "rm -rf *": "deny",
      "run-in-tmux-pane bundle exec rspec*": "allow",
      "run-in-tmux-pane fgdku*": "allow",
      "run-in-tmux-pane gpsup*": "allow",
      "run-in-tmux-pane test_mr*": "allow",
      "rg *": "allow",
      "sed *": "allow",
      "shellcheck *": "allow",
      "sleep *": "allow",
      "sort*": "allow",
      "stat *": "allow",
      "strings *": "allow",
      "tail *": "allow",
      "tmux display-message *": "allow",
      "tmux list-windows *": "allow",
      "tmux show -s terminal-features": "allow",
      "tmux show-options *": "allow",
      "type *": "allow",
      "vale *": "allow",
      "wc *": "allow",
      "which *": "allow",
      "curl *": "deny",
      "wget *": "deny",
      "xxd *": "allow",
      "yamllint *": "allow"
    },
    "external_directory": {
      "~/.agents/docs/*": "allow",
      "/tmp": "allow",
      "/tmp/*": "allow",
      "/private/tmp/**/*": "allow",
      "/private/tmp/*": "allow",
      "/private/tmp": "allow"
    },
    // Denied: use Glean MCP instead (faster, more comprehensive, indexes more sources)
    "gitlab_documentation_search": "deny",
    "glob": "allow",
    "grep": "allow",
    "knowledge-graph_get_references": "allow",
    "knowledge-graph_list_projects": "allow",
    "knowledge-graph_read_definitions": "allow",
    "knowledge-graph_repo_map": "allow",
    "knowledge-graph_search_codebase_definitions": "allow",
    "lazy-mcp_describe_commands": "allow",
    "lazy-mcp_invoke_command": "allow",
    "lazy-mcp_list_commands": "allow",
    "lazy-mcp_list_servers": "allow",
    "doom_loop": "ask",
    "edit": "ask",
    "list": "allow",
    "todoread": "allow",
    "webfetch": "ask",
    "websearch": "ask",
    "~/.agents/docs/*": "allow",
    "~/.aws/*": "deny",
    "~/.config/opencode/*": "deny",
    "~/.gnupg/*": "deny",
    "~/.netrc": "deny",
    "~/.ssh/*": "deny",
    "skill": {
      "clickhouse": "allow",
      "db-migrations": "allow",
      "gdk": "allow",
      "git-helpers": "allow",
      "gitlab-review": "allow",
      "glab": "allow",
      "hammerspoon": "allow",
      "mr-pipeline": "allow",
      "mr-workflow": "allow",
      "psql": "allow",
      "repo-bootstrap": "allow",
      "run-in-tmux-pane": "allow",
      "tool-routing": "allow"
    },
    "task": {
      "general": "allow",
      "explore": "allow",
      "security-reviewer": "allow",
      "database-reviewer": "allow",
      "clickhouse-reviewer": "allow",
      "performance-reviewer": "allow",
      "qa-reviewer": "allow",
      "frontend-reviewer": "allow",
      "backend-reviewer": "allow",
      "documentation-reviewer": "allow",
      "analytics-reviewer": "allow",
      "graphql-reviewer": "allow",
      "rest-api-reviewer": "allow",
      "workers-reviewer": "allow",
      "feature-flags-reviewer": "allow"
    },
    "todowrite": "allow"
  }
}
