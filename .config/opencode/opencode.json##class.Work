{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "plugin": [
    "@gitlab/opencode-gitlab-plugin",
    "@mohak34/opencode-notifier@latest",
    "opencode-wakatime"
  ],
  "mcp": {
    "lazy-mcp": {
      "type": "local",
      "command": [
        "mise",
        "x",
        "npm:lazy-mcp",
        "--",
        "lazy-mcp",
        "--config",
        "~/.config/lazy-mcp/servers.json"
      ],
      "enabled": true
    }
  },
  "enabled_providers": ["gitlab"],
  "small_model": "gitlab/duo-chat-haiku-4-5",
  "share": "disabled",
  "snapshot": false,
  "permission": {
    "*": "ask",
    "bash": {
      "*": "ask",
      "bundle exec rspec*": "allow",
      "bundle exec rubocop*": "allow",
      "RAILS_ENV=test bundle exec rspec*": "allow",
      "RAILS_ENV=test bundle exec rubocop*": "allow",
      "date*": "allow",
      "echo*": "allow",
      "find*": "allow",
      "git add*": "allow",
      "git blame*": "allow",
      "git branch*": "allow",
      "git diff*": "allow",
      "git grep*": "allow",
      "git log*": "allow",
      "git ls-files*": "allow",
      "git remote -v": "allow",
      "git rev-parse*": "allow",
      "git show*": "allow",
      "git status*": "allow",
      "glab issue list *": "allow",
      "glab issue view *": "allow",
      "glab mr view *": "allow",
      "glab mr list *": "allow",
      "glab mr create *": "allow",
      "glab mr diff *": "allow",
      "go build*": "allow",
      "go test*": "allow",
      "go vet*": "allow",
      "golangci-lint run*": "allow",
      "grep*": "allow",
      "head*": "allow",
      "ls*": "allow",
      "markdownlint *": "allow",
      "mise ls *": "allow",
      "mise ls-remote *": "allow",
      "npx markdownlint-cli2 *": "allow",
      "pre-commit *": "allow",
      "rg*": "allow",
      "sleep *": "allow",
      "tail*": "allow",
      "vale *": "allow",
      "wc *": "allow",
      "which*": "allow"
    },
    "external_directory": {
      "/tmp": "allow",
      "/tmp/*": "allow",
      "/private/tmp/**/*": "allow",
      "/private/tmp/*": "allow",
      "/private/tmp": "allow"
    },
    "glob": "allow",
    "grep": "allow",
    "knowledge-graph_list_projects": "allow",
    "knowledge-graph_read_definitions": "allow",
    "knowledge-graph_repo_map": "allow",
    "knowledge-graph_search_codebase_definitions": "allow",
    "lazy-mcp_describe_commands": "allow",
    "lazy-mcp_invoke_command": "allow",
    "lazy-mcp_list_commands": "allow",
    "lazy-mcp_list_servers": "allow",
    "read": "allow",
    "skill": { "clickhouse": "allow", "glab": "allow", "psql": "allow" },
    "task": {
      "general": "allow",
      "explore": "allow",
      "review-security": "allow",
      "review-database": "allow",
      "review-clickhouse": "allow",
      "review-performance": "allow",
      "review-qa": "allow",
      "review-frontend": "allow",
      "review-backend": "allow",
      "review-docs": "allow",
      "review-analytics": "allow",
      "review-graphql": "allow"
    },
    "todowrite": "allow"
  }
}
