{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-anthropic-auth@latest",
    "opencode-homeassistant",
    "opencode-terminal-progress",
    "opencode-wakatime"
  ],
  "default_agent": "plan",
  "small_model": "gitlab/duo-chat-haiku-4-5",
  "provider": {
    "anthropic": {
      "options": {
        "setCacheKey": true
      }
    }
  },
  "mcp": {
    "lazy-mcp": {
      "type": "local",
      "command": [
        "mise",
        "x",
        "npm:lazy-mcp",
        "--",
        "lazy-mcp",
        "--config",
        "~/.config/lazy-mcp/servers.json"
      ],
      "enabled": true
    }
  },
  "share": "disabled",
  "snapshot": false,
  "permission": {
    "*": "ask",
    "bash": {
      "*": "ask",
      "ag *": "allow",
      "bat *": "allow",
      "bundle exec rspec*": "allow",
      "bundle exec rubocop*": "allow",
      "cat *": "allow",
      "comm *": "allow",
      "date *": "allow",
      "diff *": "allow",
      "docker container ls*": "allow",
      "docker image ls*": "allow",
      "docker images*": "allow",
      "docker info*": "allow",
      "docker inspect *": "allow",
      "docker network inspect *": "allow",
      "docker network ls *": "allow",
      "docker ps*": "allow",
      "docker stats*": "allow",
      "docker version*": "allow",
      "docker volume ls *": "allow",
      "echo *": "allow",
      "env *": "allow",
      "fd *": "allow",
      "file *": "allow",
      "find *": "allow",
      "fzf *": "allow",
      "git add*": "allow",
      "git blame*": "allow",
      "git branch*": "allow",
      "git diff*": "allow",
      "git fetch *": "allow",
      "git grep*": "allow",
      "git log*": "allow",
      "git ls-files*": "allow",
      "git ls-remote *": "allow",
      "git merge-base *": "allow",
      "git reflog *": "allow",
      "git remote -v": "allow",
      "git rev-parse*": "allow",
      "git show*": "allow",
      "git status*": "allow",
      "go build*": "allow",
      "go test*": "allow",
      "go vet*": "allow",
      "golangci-lint run*": "allow",
      "grep *": "allow",
      "head *": "allow",
      "hostname *": "allow",
      "less *": "allow",
      "ls *": "allow",
      "mise ls *": "allow",
      "mise ls-remote *": "allow",
      "mise tasks": "allow",
      "mise tasks --list": "allow",
      "mise tasks --silent": "allow",
      "mise tasks info *": "allow",
      "mise tasks ls *": "allow",
      "more *": "allow",
      "ping *": "allow",
      "pre-commit *": "allow",
      "printenv *": "allow",
      "pwd *": "allow",
      "readlink *": "allow",
      "rg *": "allow",
      "sleep *": "allow",
      "sort *": "allow",
      "stat *": "allow",
      "strings *": "allow",
      "tail *": "allow",
      "type *": "allow",
      "uname *": "allow",
      "uniq *": "allow",
      "wc *": "allow",
      "whereis *": "allow",
      "which *": "allow",
      "yamllint *": "allow",
      "gh issue view *": "allow",
      "gh pr view *": "allow",
      "gh run list *": "allow",
      "gh run view *": "allow"
    },
    "external_directory": {
      "/private/tmp/**/*": "allow",
      "/private/tmp/*": "allow",
      "/private/tmp": "allow"
    },
    "glob": "allow",
    "grep": "allow",
    "lazy-mcp_describe_commands": "allow",
    "lazy-mcp_invoke_command": "allow",
    "lazy-mcp_list_commands": "allow",
    "lazy-mcp_list_servers": "allow",
    "read": "allow",
    "skill": { "gh": "allow" },
    "task": {
      "general": "allow",
      "explore": "allow"
    },
    "todowrite": "allow",
  }
}
