{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-anthropic-auth@latest",
    "opencode-wakatime"
  ],
  "default_agent": "plan",
  "small_model": "gitlab/duo-chat-haiku-4-5",
  "provider": {
    "anthropic": {
      "options": {
        "setCacheKey": true
      }
    }
  },
  "mcp": {
    "lazy-mcp": {
      "type": "local",
      "command": [
        "mise",
        "x",
        "npm:lazy-mcp",
        "--",
        "lazy-mcp",
        "--config",
        "~/.config/lazy-mcp/servers.json"
      ],
      "enabled": true
    }
  },
  "share": "disabled",
  "snapshot": false,
  "permission": {
    "*": "ask",
    "bash": {
      "*": "ask",
      "bundle exec rspec*": "allow",
      "bundle exec rubocop*": "allow",
      "echo*": "allow",
      "find*": "allow",
      "git add*": "allow",
      "git blame*": "allow",
      "git branch*": "allow",
      "git diff*": "allow",
      "git --no-pager diff*": "allow",
      "git grep*": "allow",
      "git --no-pager log*": "allow",
      "git log*": "allow",
      "git ls-files*": "allow",
      "git remote -v": "allow",
      "git rev-parse*": "allow",
      "git show*": "allow",
      "git --no-pager status*": "allow",
      "git status*": "allow",
      "docker ps*": "allow",
      "docker container ls*": "allow",
      "docker images*": "allow",
      "docker image ls*": "allow",
      "docker info*": "allow",
      "docker version*": "allow",
      "docker stats*": "allow",
      "docker network inspect *": "allow",
      "docker network ls *": "allow",
      "docker volume ls *": "allow",
      "docker inspect *": "allow",
      "go build*": "allow",
      "go test*": "allow",
      "go vet*": "allow",
      "golangci-lint run*": "allow",
      "grep*": "allow",
      "head*": "allow",
      "ls*": "allow",
      "mise ls *": "allow",
      "mise ls-remote *": "allow",
      "ping *": "allow",
      "pre-commit *": "allow",
      "rg*": "allow",
      "sleep *": "allow",
      "tail*": "allow",
      "wc *": "allow",
      "which*": "allow",
      "yamllint *": "allow",
      "gh issue view *": "allow",
      "gh pr view *": "allow",
      "gh run list *": "allow",
      "gh run view *": "allow",
    },
    "glob": "allow",
    "grep": "allow",
    "lazy-mcp_describe_commands": "allow",
    "lazy-mcp_invoke_command": "allow",
    "lazy-mcp_list_commands": "allow",
    "lazy-mcp_list_servers": "allow",
    "read": "allow",
    "skill": { "gh": "allow" },
    "task": {
      "general": "allow",
      "explore": "allow"
    },
    "todowrite": "allow",
  }
}
