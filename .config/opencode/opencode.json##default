{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@mohak34/opencode-notifier@latest",
    "opencode-anthropic-auth@latest",
    "opencode-homeassistant@latest",
    "opencode-terminal-progress@latest",
    "opencode-tmux-indicator@latest",
    "opencode-wakatime@latest"
  ],
  "default_agent": "plan",
  "small_model": "gitlab/duo-chat-haiku-4-5",
  "provider": {
    "anthropic": {
      "options": {
        "setCacheKey": true
      }
    }
  },
  "mcp": {
    "lazy-mcp": {
      "type": "local",
      "command": [
        "mise",
        "x",
        "npm:lazy-mcp",
        "--",
        "lazy-mcp",
        "--config",
        "~/.config/lazy-mcp/servers.json"
      ],
      "enabled": true
    }
  },
  "provider": {
    "gitlab": {
      "models": {
        "duo-chat-opus-4-6": {
          "cost": {
            "input": 5, "output": 25, "cache_read": 0.50, "cache_write": 6.25,
            "context_over_200k": { "input": 10, "output": 37.50, "cache_read": 1.00, "cache_write": 12.50 }
          }
        },
        "duo-chat-opus-4-5": {
          "cost": {
            "input": 5, "output": 25, "cache_read": 0.50, "cache_write": 6.25,
            "context_over_200k": { "input": 10, "output": 37.50, "cache_read": 1.00, "cache_write": 12.50 }
          }
        },
        "duo-chat-sonnet-4-6": {
          "cost": {
            "input": 3, "output": 15, "cache_read": 0.30, "cache_write": 3.75,
            "context_over_200k": { "input": 6, "output": 22.50, "cache_read": 0.60, "cache_write": 7.50 }
          }
        },
        "duo-chat-sonnet-4-5": {
          "cost": {
            "input": 3, "output": 15, "cache_read": 0.30, "cache_write": 3.75,
            "context_over_200k": { "input": 6, "output": 22.50, "cache_read": 0.60, "cache_write": 7.50 }
          }
        },
        "duo-chat-sonnet-4": {
          "cost": {
            "input": 3, "output": 15, "cache_read": 0.30, "cache_write": 3.75,
            "context_over_200k": { "input": 6, "output": 22.50, "cache_read": 0.60, "cache_write": 7.50 }
          }
        },
        "duo-chat-opus-4": {
          "cost": {
            "input": 15, "output": 75, "cache_read": 1.50, "cache_write": 18.75,
            "context_over_200k": { "input": 30, "output": 112.50, "cache_read": 3.00, "cache_write": 37.50 }
          }
        },
        "duo-chat-haiku-4-5": {
          "cost": { "input": 1, "output": 5, "cache_read": 0.10, "cache_write": 1.25 }
        }
      }
    }
  },
  "share": "disabled",
  "snapshot": false,
  "permission": {
    "*": "ask",
    "bash": {
      "*": "ask",
      "ag *": "allow",
      "bat *": "allow",
