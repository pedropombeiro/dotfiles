      "md5 *": "allow",
      "mise ls *": "allow",
      "mise ls-remote *": "allow",
      "mise tasks": "allow",
      "mise tasks --list": "allow",
      "mise tasks --silent": "allow",
      "mise tasks info *": "allow",
      "mise tasks ls *": "allow",
      "more *": "allow",
      "ping *": "allow",
      "pre-commit *": "allow",
      "printenv *": "allow",
      "printf *": "allow",
      "ps *": "allow",
      "pwd*": "allow",
      "readlink *": "allow",
      "rm -rf *": "deny",
      "run-in-tmux-pane gpsup*": "allow",
      "rg *": "allow",
      "sed *": "allow",
      "shellcheck *": "allow",
      "sleep *": "allow",
      "sort*": "allow",
      "stat *": "allow",
      "strings *": "allow",
      "tail *": "allow",
      "tmux display-message *": "allow",
      "tmux list-windows *": "allow",
      "tmux show -s terminal-features": "allow",
      "tmux show-options *": "allow",
      "type *": "allow",
      "uname *": "allow",
      "uniq *": "allow",
      "wc *": "allow",
      "whereis *": "allow",
      "which *": "allow",
      "curl *": "deny",
      "wget *": "deny",
      "xxd *": "allow",
      "yamllint *": "allow",
      "gh issue view *": "allow",
      "gh pr view *": "allow",
      "gh run list *": "allow",
      "gh run view *": "allow"
    },
    "external_directory": {
      "/private/tmp/**/*": "allow",
      "/private/tmp/*": "allow",
      "/private/tmp": "allow"
    },
    "glob": "allow",
    "grep": "allow",
    "lazy-mcp_describe_commands": "allow",
    "lazy-mcp_invoke_command": "allow",
    "lazy-mcp_list_commands": "allow",
    "lazy-mcp_list_servers": "allow",
    "doom_loop": "ask",
    "edit": "ask",
    "list": "allow",
    "todoread": "allow",
    "webfetch": "ask",
    "websearch": "ask",
    "~/.agents/docs/*": "allow",
    "~/.aws/*": "deny",
    "~/.config/opencode/*": "deny",
    "~/.gnupg/*": "deny",
    "~/.netrc": "deny",
    "~/.ssh/*": "deny",
    "skill": { "gh": "allow", "hammerspoon": "allow" },
    "task": {
      "general": "allow",
      "explore": "allow"
    },
    "todowrite": "allow"
  }
}
