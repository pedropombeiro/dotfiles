{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@mohak34/opencode-notifier@latest",
    "opencode-anthropic-auth@latest",
    "opencode-atuin-history@latest",
    "opencode-homeassistant@latest",
    "opencode-terminal-progress@latest",
    "opencode-tmux-indicator@latest",
    "opencode-wakatime@latest"
  ],
  "default_agent": "plan",
  "small_model": "gitlab/duo-chat-gpt-5-4-nano",
  "mcp": {
    "lazy-mcp": {
      "type": "local",
      "command": [
        "mise",
        "x",
        "npm:lazy-mcp",
        "--",
        "lazy-mcp",
        "--config",
        "~/.config/lazy-mcp/servers.json"
      ],
      "enabled": true
    }
  },
  "provider": {
    "anthropic": {
      "options": {
        "setCacheKey": true
      }
    },
    "gitlab": {
      "models": {
        "duo-workflow-opus-4-6": {
          "cost": {
            "input": 5, "output": 25, "cache_read": 0.50, "cache_write": 6.25
          }
        },
        "duo-chat-opus-4-6": {
          "cost": {
            "input": 5, "output": 25, "cache_read": 0.50, "cache_write": 6.25
          }
        },
        "duo-chat-opus-4-5": {
          "cost": {
            "input": 5, "output": 25, "cache_read": 0.50, "cache_write": 6.25
          }
        },
        "duo-chat-sonnet-4-6": {
          "cost": {
            "input": 3, "output": 15, "cache_read": 0.30, "cache_write": 3.75
          }
        },
        "duo-chat-sonnet-4-5": {
          "cost": {
            "input": 3, "output": 15, "cache_read": 0.30, "cache_write": 3.75
          }
        },
        "duo-chat-sonnet-4": {
          "cost": {
            "input": 3, "output": 15, "cache_read": 0.30, "cache_write": 3.75
          }
        },
        "duo-chat-opus-4": {
          "cost": {
            "input": 15, "output": 75, "cache_read": 1.50, "cache_write": 18.75
          }
        },
        "duo-workflow-haiku-4-5": {
          "cost": { "input": 1, "output": 5, "cache_read": 0.10, "cache_write": 1.25 }
        },
        "duo-chat-haiku-4-5": {
          "cost": { "input": 1, "output": 5, "cache_read": 0.10, "cache_write": 1.25 }
        },
        "duo-chat-gpt-5-3-codex": {
          "cost": { "input": 1.75, "output": 14, "cache_read": 0.175 }
        },
        "duo-chat-gpt-5-4": {
          "cost": { "input": 2.50, "output": 15, "cache_read": 0.25 }
        },
        "duo-chat-gpt-5-4-mini": {
          "cost": { "input": 1.10, "output": 4.40, "cache_read": 0.11 }
        },
        "duo-chat-gpt-5-4-nano": {
          "cost": { "input": 0.50, "output": 2.00, "cache_read": 0.05 }
        }
      }
    }
  },
  "share": "disabled",
  "autoupdate": true,
  "server": {
    "hostname": "127.0.0.1",
    "mdns": false
  },
  "snapshot": false,
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "bash": {
      "*": "ask",
      "ag *": "allow",
      "bat *": "allow",
      "bundle exec rspec*": "allow",
      "bundle exec rubocop*": "allow",
      "cat *": "allow",
      "comm *": "allow",
      "date": "allow",
      "date *": "allow",
      "diff *": "allow",
      "docker container ls*": "allow",
      "docker image ls*": "allow",
      "docker images*": "allow",
      "docker info*": "allow",
      "docker inspect *": "allow",
      "docker network inspect *": "allow",
      "docker network ls *": "allow",
      "docker ps*": "allow",
      "docker stats*": "allow",
      "docker version*": "allow",
      "docker volume ls *": "allow",
      "echo *": "allow",
      "env *": "allow",
      "fd *": "allow",
      "file *": "allow",
      "find *": "allow",
      "fzf *": "allow",
      "git add *": "allow",
      "git blame *": "allow",
      "git branch*": "allow",
      "git branch *": "allow",
      "git check-ignore *": "allow",
      "git commit*": "ask",
      "git commit *": "ask",
      "git diff*": "allow",
      "git fetch *": "allow",
      "git grep*": "allow",
      "git log*": "allow",
      "git ls-files*": "allow",
      "git ls-remote *": "allow",
      "git merge-base *": "allow",
      "git push*": "ask",
      "git push *": "ask",
      "git reflog *": "allow",
      "git remote -v": "allow",
      "git rev-parse*": "allow",
      "git show*": "allow",
      "git status*": "allow",
      "go build*": "allow",
      "go test*": "allow",
      "go vet*": "allow",
      "golangci-lint run*": "allow",
      "grep *": "allow",
      "head *": "allow",
      "hostname": "allow",
      "less *": "allow",
      "ls *": "allow",
