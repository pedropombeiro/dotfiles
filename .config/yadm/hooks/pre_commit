#!/usr/bin/env bash

YADM_SCRIPTS=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/../scripts" &>/dev/null && pwd)

source "${YADM_SCRIPTS}/colors.sh"

alt_basenames=$(yadm ls-files | grep -E '##' | sed 's/##.*//' | sort -u)

if [[ -z "${alt_basenames}" ]]; then
  exit 0
fi

staged=$(yadm diff --cached --name-only --diff-filter=A)
bad_files=()

while IFS= read -r file; do
  [[ -z "${file}" ]] && continue
  if echo "${alt_basenames}" | grep -qxF "${file}"; then
    bad_files+=("${file}")
  fi
done <<<"${staged}"

if [[ ${#bad_files[@]} -gt 0 ]]; then
  printf "${RED}%s${NC}\n" "ERROR: The following staged files are yadm alt symlinks and must not be committed:"
  for f in "${bad_files[@]}"; do
    printf "  ${YELLOW}%s${NC}\n" "${f}"
  done
  printf "\n%s\n" "Run 'yadm reset HEAD <file>' to unstage them."
  exit 1
fi
