<layout>
    <composite x="260" y="30" name="date_and_time">
        <component type="datetime" x="0" y="0" format="%Y/%m/%d" size="24" align="right"/>
        <component type="datetime" x="0" y="36" format="%H:%M:%S.%f" truncate="5" size="48" align="right"/>
    </composite>

    <composite x="3072" y="0" name="gps_info">
        <frame name="gps-lock" x="226" y="24" width="48" height="48" bg="0,0,0,128" cr="5" opacity="0.4">
            <component type="gps-lock-icon" size="48"/>
        </frame>

        <composite y="36">
            <component type="text" x="0" y="0" size="24" align="left">GPS INFO</component>
            <component type="text" x="0" y="32" size="24" align="left">Lat: </component>
            <component type="text" x="180" y="32" size="24" align="left">Lon: </component>
            <component type="metric" x="170" y="32" metric="lat" dp="6" size="24" align="right" cache="False"/>
            <component type="metric" x="360" y="32" metric="lon" dp="6" size="24" align="right" cache="False"/>
        </composite>
    </composite>

    <composite x="16" y="1620" name="big_mph">
        <component type="metric_unit" metric="speed" units="speed" size="24">{:~c}</component>
        <component type="metric" x="0" y="0" metric="speed" units="speed" dp="0" size="200" />
    </composite>

    <composite x="16" y="1840" name="gears">
        <component type="text" x="0" y="0" size="24">GEARS (F x R)</component>
        <component type="metric" x="0" y="27" metric="gear.front" dp="0" size="48"/>
        <component type="text" x="60" y="27" size="48">x</component>
        <component type="metric" x="110" y="27" metric="gear.rear" dp="0" size="48"/>
    </composite>

    <component type="chart" name="gradient_chart" x="500" y="1960" units="alt" />

    <composite x="280" y="1960" name="gradient">
        <component type="text" x="105" y="0" size="24">SLOPE(%)</component>
        <component type="icon" x="0" y="0" file="slope-triangle.png" size="96"/>
        <component type="metric" x="105" y="27" metric="gradient" dp="0" size="48" />
    </composite>

    <composite x="16" y="1960" name="altitude">
        <component type="metric_unit" x="105" y="0" metric="alt" units="alt" size="24">ALT({:~C})</component>
        <component type="icon" x="0" y="0" file="mountain.png" size="96"/>
        <component type="metric" x="105" y="27" metric="alt" units="alt" dp="0" size="48" />
    </composite>

    <composite x="3770" y="1570" name="temperature">
        <component type="metric_unit" x="-105" y="0" size="24" align="right" metric="temp" units="temp">TEMP({:~C})</component>
        <component type="icon" x="-96" y="0" file="thermometer.png" size="96"/>
        <component type="metric" x="-105" y="27" dp="0" size="48" align="right" metric="temp" units="temp"/>
    </composite>

    <composite x="3770" y="1700" name="cadence">
        <component type="text" x="-105" y="0" size="24" align="right">RPM</component>
        <component type="icon" x="-96" y="0" file="gauge.png" size="96"/>
        <component type="metric" x="-105" y="27" metric="cadence" dp="0" size="48" align="right"/>
    </composite>

    <composite x="3770" y="1830" name="heartbeat">
        <component type="text" x="-105" y="0" size="24" align="right">BPM</component>
        <component type="icon" x="-96" y="0" file="heartbeat.png" size="96"/>
        <component type="metric" x="-105" y="27" metric="hr" dp="0" size="48" align="right"/>
    </composite>

    <composite x="3770" y="1960" name="power">
        <component type="text" x="-105" y="0" size="24" align="right">Watt</component>
        <component type="icon" x="-96" y="0" file="power.png" size="96"/>
        <component type="metric" x="-105" y="27" metric="power" dp="0" size="48" align="right"/>
        <translate x="-200" y="100" name="power-zone">
            <component type="zone-bar" width="200" height="18" metric="power" max="600" z1="150" z2="250" z3="350" outline="255,255,255,80" outline-width="1" zone-divider="255,255,255,60" z0-rgb="67,235,52,200" z1-rgb="67,235,52,200" z2-rgb="240,232,19,200" z3-rgb="207,19,2,200"/>
        </translate>
    </composite>

    <component type="moving_map" name="moving_map" x="3260" y="100" size="512" zoom="17" corner_radius="35" />
    <component type="journey_map" name="journey_map" x="3260" y="700" size="512" corner_radius="35"/>
</layout>
