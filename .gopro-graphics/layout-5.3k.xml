<layout>
    <composite x="360" y="42" name="date_and_time">
        <component type="datetime" x="0" y="0" format="%Y/%m/%d" size="33" align="right"/>
        <component type="datetime" x="0" y="50" format="%H:%M:%S" size="66" align="right"/>
    </composite>

    <composite x="4864" y="0" name="gps_info">
        <frame name="gps-lock" x="-318" y="33" width="66" height="66" bg="0,0,0,128" cr="7" opacity="0.4">
            <component type="gps-lock-icon" size="66"/>
        </frame>

        <composite y="50">
            <component type="text" x="-221" y="0" size="33" align="left">Lat: </component>
            <component type="text" x="28" y="0" size="33" align="left">Lon: </component>
            <component type="metric" x="14" y="0" metric="lat" dp="6" size="33" align="right" cache="False"/>
            <component type="metric" x="304" y="0" metric="lon" dp="6" size="33" align="right" cache="False"/>
        </composite>
    </composite>

    <!-- ENVIRONMENTAL (left column, top to bottom: temp, altitude, slope, chart) -->
    <composite x="22" y="2227" name="temperature">
        <component type="metric_unit" x="145" y="0" size="33" metric="temp" units="temp">TEMP({:~C})</component>
        <component type="icon" x="0" y="0" file="thermometer.png" size="133"/>
        <component type="metric" x="145" y="37" dp="0" size="66" metric="temp" units="temp"/>
    </composite>

    <composite x="22" y="2393" name="altitude">
        <component type="metric_unit" x="145" y="0" metric="alt" units="alt" size="33">ALT({:~C})</component>
        <component type="icon" x="0" y="0" file="mountain.png" size="133"/>
        <component type="metric" x="145" y="37" metric="alt" units="alt" dp="0" size="66" />
    </composite>

    <composite x="22" y="2559" name="gradient">
        <component type="text" x="145" y="0" size="33">SLOPE(%)</component>
        <component type="icon" x="0" y="0" file="slope-triangle.png" size="133"/>
        <component type="metric" x="145" y="37" metric="gradient" dp="0" size="66" />
    </composite>

    <component type="chart" name="gradient_chart" x="22" y="2739" units="alt" width="581" height="166" />

    <!-- PERFORMANCE (right column, bottom to top: speed hero, power, gears, RPM, HR) -->
    <composite x="5215" y="1895" name="heartbeat">
        <component type="text" x="-145" y="0" size="33" align="right">BPM</component>
        <component type="icon" x="-133" y="0" file="heartbeat.png" size="133"/>
        <component type="metric" x="-145" y="37" metric="hr" dp="0" size="66" align="right"/>
    </composite>

    <composite x="5215" y="2061" name="cadence">
        <component type="text" x="-145" y="0" size="33" align="right">RPM</component>
        <component type="icon" x="-133" y="0" file="gauge.png" size="133"/>
        <component type="metric" x="-145" y="37" metric="cadence" dp="0" size="66" align="right"/>
    </composite>

    <composite x="5215" y="2227" name="gears">
        <component type="text" x="-76" y="0" size="33" align="centre">GEARS (F x R)</component>
        <component type="metric" x="-152" y="37" metric="gear.front" dp="0" size="66" align="right"/>
        <component type="text" x="-69" y="37" size="66" align="right">x</component>
        <component type="metric" x="0" y="37" metric="gear.rear" dp="0" size="66" align="right"/>
    </composite>

    <composite x="5215" y="2393" name="power">
        <component type="text" x="-145" y="0" size="33" align="right">Watt</component>
        <component type="icon" x="-133" y="0" file="power.png" size="133"/>
        <component type="metric" x="-145" y="37" metric="power" dp="0" size="66" align="right"/>
        <translate x="-277" y="138" name="power-zone">
            <component type="zone-bar" width="277" height="25" metric="power" max="600" z1="150" z2="250" z3="350" outline="255,255,255,80" outline-width="1" zone-divider="255,255,255,60" z0-rgb="67,235,52,200" z1-rgb="67,235,52,200" z2-rgb="240,232,19,200" z3-rgb="207,19,2,200"/>
        </translate>
    </composite>

    <composite x="5215" y="2628" name="big_kph">
        <component type="metric_unit" x="-277" metric="speed" units="speed" size="33" align="right">{:~c}</component>
        <component type="metric" x="0" y="0" metric="speed" units="speed" dp="0" size="221" align="right" />
    </composite>

    <component type="moving_map" name="moving_map" x="4510" y="138" size="708" zoom="17" corner_radius="48" />
    <component type="journey_map" name="journey_map" x="4510" y="968" size="708" corner_radius="48"/>
</layout>
