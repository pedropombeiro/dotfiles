#!/usr/bin/env sh
# Overlay FIT-file activity data onto a GoPro video via gopro-dashboard.py.
#
# Wraps the routine flags so a typical run is just the input video + FIT file.
# The video's embedded creation_time is read directly (--video-time-start
# video-created), so the old "touch -d <encoded timestamp>" step is unnecessary.
# A --touch fallback reproduces the legacy flow (ffprobe creation_time ->
# touch -d -> --video-time-start file-accessed) for files with bad metadata.
#
# To correct a wrong camera clock, use --offset to shift the timestamp. This
# implies --touch (the offset is applied to the touched creation_time, since
# gopro-dashboard.py itself has no time-shift option). Offset accepts a signed
# duration like +90, -1m30s, +2h, -45s (bare numbers are seconds).
#
# Usage:
#   gopro-overlay <input.mp4> <activity.fit>
#   gopro-overlay -o out.mp4 <input.mp4> <activity.fit>
#   gopro-overlay --touch <input.mp4> <activity.fit>
#   gopro-overlay --offset -90 <input.mp4> <activity.fit>  # clock 90s fast
#   gopro-overlay -n <input.mp4> <activity.fit>            # dry-run
#   gopro-overlay --smooth-grade <input.mp4> <activity.fit>  # smooth slope widget
#   gopro-overlay --overlay-only <input.mp4> <activity.fit>  # transparent overlay
#   gopro-overlay <input.mp4> <activity.fit> -- --map-style osm   # passthrough
#
# --smooth-grade pre-processes the FIT via fit-smooth-grade to inject a smoothed
# `grade` field, which gopro-dashboard's gradient widget prefers over its own
# noisy rise/run computation. Produces <activity>_smoothed.fit and uses that.
#
# --overlay-only renders the gauges as a TRANSPARENT clip (lossless QuickTime
# Animation / QTRLE with alpha, profile overlay-qtrle) instead of compositing
# onto the source video. Superimpose it over the graded footage in DaVinci
# Resolve (graded clip on V1, this overlay on V2). The source video is still
# read so timing and overlay dimensions match the clip. Output defaults to
# <basename>.overlay.mov.
#
# Layout is auto-selected by video resolution when GOPRO_OVERLAY_LAYOUT is unset:
#   5312x2988 (5.3K) -> layout-5.3k.xml
#   3840x2160 (4K)   -> layout-4k-1.5x.xml  (default for unknown resolutions)
# Override with GOPRO_OVERLAY_LAYOUT, --layout-xml FILE, or --no-layout.
#
# Output defaults to ${GOPRO_OVERLAY_OUTDIR:-$HOME/Downloads}/<basename>.output.mp4
# (or <basename>.overlay.mov with --overlay-only)

set -e

prog=$(basename "$0")

usage() {
  sed -n '2,41p' "$0" | sed 's/^# \{0,1\}//'
}

input=""
fit=""
output=""
layout_xml="${GOPRO_OVERLAY_LAYOUT:-}"
layout_xml_override=0
use_touch=0
offset=""
dry_run=0
smooth_grade=0
overlay_only=0
passthrough=0
extra_args=""

while [ $# -gt 0 ]; do
  if [ "$passthrough" -eq 1 ]; then
    extra_args="$extra_args $1"
    shift
    continue
  fi
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    -o|--output)
      output="$2"
      shift 2
      ;;
    --layout-xml)
      layout_xml="$2"
      layout_xml_override=1
      shift 2
      ;;
    --no-layout)
      layout_xml=""
      layout_xml_override=1
      shift
      ;;
    --touch)
      use_touch=1
      shift
      ;;
    --offset)
      offset="$2"
      use_touch=1
      shift 2
      ;;
    --smooth-grade)
      smooth_grade=1
      shift
      ;;
    --overlay-only)
      overlay_only=1
      shift
      ;;
    -n|--dry-run)
      dry_run=1
      shift
      ;;
    --)
      passthrough=1
      shift
      ;;
    -*)
      echo "$prog: error: unknown option: $1" >&2
      exit 1
      ;;
    *)
      if [ -z "$input" ]; then
        input="$1"
      elif [ -z "$fit" ]; then
        fit="$1"
      else
        echo "$prog: error: unexpected argument: $1" >&2
        exit 1
      fi
      shift
      ;;
  esac
done

if [ -z "$input" ] || [ -z "$fit" ]; then
  echo "$prog: error: both <input.mp4> and <activity.fit> are required" >&2
  echo >&2
  usage >&2
  exit 1
fi

if [ ! -f "$input" ]; then
  echo "$prog: error: input video not found: $input" >&2
  exit 1
fi

if [ ! -f "$fit" ]; then
  echo "$prog: error: FIT file not found: $fit" >&2
  exit 1
fi

if ! command -v gopro-dashboard.py >/dev/null 2>&1; then
  echo "$prog: error: gopro-dashboard.py not found on PATH" >&2
  exit 1
fi

if [ "$smooth_grade" -eq 1 ]; then
  if ! command -v fit-smooth-grade >/dev/null 2>&1; then
    echo "$prog: error: --smooth-grade requires fit-smooth-grade on PATH" >&2
    exit 1
  fi
  fit_stem="${fit%.*}"
  smoothed_fit="${fit_stem}_smoothed.fit"
  if [ "$dry_run" -eq 1 ]; then
    echo "$prog: would run: fit-smooth-grade -o $smoothed_fit $fit" >&2
  else
    fit-smooth-grade -o "$smoothed_fit" "$fit"
  fi
  fit="$smoothed_fit"
fi

if [ -z "$output" ]; then
  outdir="${GOPRO_OVERLAY_OUTDIR:-$HOME/Downloads}"
  base=$(basename "$input")
  stem="${base%.*}"
  if [ "$overlay_only" -eq 1 ]; then
    # Transparent overlay (lossless QTRLE with alpha) to superimpose in an editor;
    # .overlay.mov avoids colliding with the burned-in .output.mp4 renders.
    output="$outdir/$stem.overlay.mov"
  else
    output="$outdir/$stem.output.mp4"
  fi
fi

if [ "$layout_xml_override" -eq 0 ] && [ -z "$layout_xml" ]; then
  layout_dir="$HOME/.gopro-graphics"
  if command -v ffprobe >/dev/null 2>&1; then
    vid_dims=$(ffprobe -v error -select_streams v:0 \
      -show_entries stream=width,height \
      -of default=noprint_wrappers=1:nokey=1 "$input" 2>/dev/null | \
      awk 'NR==1{w=$0} NR==2{print w"x"$0}')
    case "$vid_dims" in
      5312x2988)
        layout_xml="$layout_dir/layout-5.3k.xml"
        echo "$prog: detected 5.3K video ($vid_dims), using layout-5.3k.xml" >&2
        ;;
      3840x2160)
        layout_xml="$layout_dir/layout-4k-1.5x.xml"
        echo "$prog: detected 4K video ($vid_dims), using layout-4k-1.5x.xml" >&2
        ;;
      *)
        layout_xml="$layout_dir/layout-4k-1.5x.xml"
        echo "$prog: warning: unrecognised resolution ($vid_dims), falling back to layout-4k-1.5x.xml" >&2
        ;;
    esac
  else
    layout_xml="$HOME/.gopro-graphics/layout-4k-1.5x.xml"
    echo "$prog: warning: ffprobe not found, falling back to layout-4k-1.5x.xml" >&2
  fi
fi

time_start="video-created"

if [ "$use_touch" -eq 1 ]; then
  if ! command -v ffprobe >/dev/null 2>&1; then
    echo "$prog: error: --touch requires ffprobe on PATH" >&2
    exit 1
  fi
  ts=$(ffprobe -v error -select_streams v:0 \
    -show_entries stream_tags=creation_time \
    -of default=noprint_wrappers=1:nokey=1 "$input" | head -n 1)
  if [ -z "$ts" ]; then
    ts=$(ffprobe -v error \
      -show_entries format_tags=creation_time \
      -of default=noprint_wrappers=1:nokey=1 "$input" | head -n 1)
  fi
  if [ -z "$ts" ]; then
    echo "$prog: error: could not read creation_time from $input" >&2
    exit 1
  fi
  if [ -n "$offset" ]; then
    offset_secs=$(printf '%s' "$offset" | awk '
      {
        s = $0
        sign = 1
        if (substr(s, 1, 1) == "+") { s = substr(s, 2) }
        else if (substr(s, 1, 1) == "-") { sign = -1; s = substr(s, 2) }
        if (s ~ /^[0-9]+$/) { print sign * s; next }
        total = 0; num = ""
        n = split(s, ch, "")
        for (i = 1; i <= n; i++) {
          c = ch[i]
          if (c ~ /[0-9]/) { num = num c }
          else if (c == "h") { total += num * 3600; num = "" }
          else if (c == "m") { total += num * 60;   num = "" }
          else if (c == "s") { total += num;        num = "" }
          else { print "ERR"; exit }
        }
        if (num != "") { print "ERR"; exit }
        print sign * total
      }')
    if [ "$offset_secs" = "ERR" ] || [ -z "$offset_secs" ]; then
      echo "$prog: error: invalid --offset value: $offset (use e.g. +90, -1m30s, +2h)" >&2
      exit 1
    fi
    base_epoch=$(date -j -u -f '%Y-%m-%dT%H:%M:%S' "${ts%%.*}" '+%s' 2>/dev/null) || {
      echo "$prog: error: could not parse creation_time '$ts' for offset" >&2
      exit 1
    }
    new_epoch=$((base_epoch + offset_secs))
    ts=$(date -j -u -r "$new_epoch" '+%Y-%m-%dT%H:%M:%SZ')
    echo "$prog: applied offset ${offset} (${offset_secs}s) -> $ts" >&2
  fi
  echo "$prog: touch -d '$ts' $input" >&2
  if [ "$dry_run" -eq 0 ]; then
    touch -d "$ts" "$input"
  fi
  time_start="file-accessed"
fi

if [ "$overlay_only" -eq 1 ]; then
  profile="overlay-qtrle"
else
  profile="apple-silicon"
fi

set -- \
  --fit "$fit" \
  --use-gpx-only --gpx-merge OVERWRITE --load ACCL GRAV CORI \
  --profile "$profile" \
  --video-time-start "$time_start" \
  --units-speed kph --units-distance km --map-style cyclosm

if [ "$overlay_only" -eq 1 ]; then
  # Produce a transparent overlay (gauges only, alpha) instead of compositing
  # onto the source video. The input video is still passed so timing, duration
  # and overlay dimensions match the clip.
  set -- "$@" --generate overlay
fi

if [ -n "$layout_xml" ]; then
  if [ ! -f "$layout_xml" ]; then
    echo "$prog: error: layout file not found: $layout_xml" >&2
    exit 1
  fi
  set -- "$@" --layout xml --layout-xml "$layout_xml"
fi

if [ -n "$extra_args" ]; then
  # shellcheck disable=SC2086
  set -- "$@" $extra_args
fi

set -- "$@" "$input" "$output"

if [ "$dry_run" -eq 1 ]; then
  printf 'gopro-dashboard.py'
  for a in "$@"; do
    printf ' %s' "$a"
  done
  printf '\n'
  exit 0
fi

echo "$prog: output -> $output" >&2
gopro-dashboard.py "$@"

# Align the output file's modification time with its embedded recording time
# (creation_time), so the rendered clip sorts/imports in DaVinci Resolve and
# Finder by when it was filmed rather than when it was rendered. The
# creation_time metadata is carried through from the source by gopro-dashboard.
if command -v ffprobe >/dev/null 2>&1 && [ -f "$output" ]; then
  out_ct=$(ffprobe -v error -show_entries format_tags=creation_time \
    -of default=noprint_wrappers=1:nokey=1 "$output" 2>/dev/null | head -n 1)
  if [ -n "$out_ct" ]; then
    # creation_time is UTC ISO-8601 (e.g. 2026-06-13T09:12:59.000000Z). Parse it
    # as UTC to an epoch, then format the local-time "touch -t" stamp so the
    # file's wall-clock mtime matches the recording instant.
    epoch=$(date -j -u -f '%Y-%m-%dT%H:%M:%S' "${out_ct%.*}" '+%s' 2>/dev/null)
    if [ -n "$epoch" ]; then
      local_stamp=$(date -j -r "$epoch" '+%Y%m%d%H%M.%S' 2>/dev/null)
      if [ -n "$local_stamp" ]; then
        touch -t "$local_stamp" "$output"
        echo "$prog: set mtime of output to recording time ($out_ct)" >&2
      fi
    fi
  fi
fi
