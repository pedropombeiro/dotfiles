
#
# `rebase_all` rebases all branches matching the "${GILAB_USERNAME}/<MR_ID>/<BRANCH_NAME>",
# striving to keep the branch dependencies intact
#

SCRIPT_DIR="${HOME}/.shellrc/zshrc.d/functions/scripts"
source "${SCRIPT_DIR}/spring-binstubs.zsh"

spring_binstubs restore
test -f db/structure.sql && git restore db/ package.json

mise x ruby -- ruby -r "${SCRIPT_DIR}/git-helpers.rb" -e rebase_all

spring_binstubs generate
