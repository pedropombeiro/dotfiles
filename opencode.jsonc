{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "task": "allow",
    "edit": {
      ".shellrc/": "allow"
    },
    "bash": {
      // YADM commands (dotfiles-specific)
      "yadm add *": "allow",
      "yadm alt": "allow",
      "yadm blame *": "allow",
      "yadm branch *": "allow",
      "yadm config --get-all *": "allow",
      "yadm diff*": "allow",
      "yadm enter *": "allow",
      "yadm grep *": "allow",
      "yadm list *": "allow",
      "yadm log *": "allow",
      "yadm ls-files*": "allow",
      "yadm push": "allow",
      "yadm show *": "allow",
      "yadm status*": "allow"
    }
  }
}
